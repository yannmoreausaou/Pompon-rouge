[
  {
    "name": "theme_info",
    "theme_name": "Pompon-rouge",
    "theme_version": "1.0.0",
    "theme_author": "Pompon-rouge",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "cinzel_n4",
        "label": "t:general.primary"
      },
      {
        "type": "font_picker",
        "id": "type_secondary_font",
        "default": "montserrat_n5",
        "label": "t:general.secondary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#F8F6F2",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#5B6770",
        "label": "t:labels.foreground"
      },
      {
        "type": "color",
        "id": "color_navy",
        "default": "#0F2D3D",
        "label": "Bleu marine (titres, menu, footer)"
      },
      {
        "type": "color",
        "id": "color_red",
        "default": "#C62828",
        "label": "Rouge (boutons principaux, accents)"
      },
      {
        "type": "color",
        "id": "color_sand",
        "default": "#E8DDC8",
        "label": "Sable (fonds sections, cartes)"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  }
]
