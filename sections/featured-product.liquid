<section class="featured-product section--sand">
  <div class="featured-product__container content-wrapper">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          <h2 class="featured-product__title" {{ block.shopify_attributes }}>{{ block.settings.title }}</h2>
        {%- when 'product' -%}
          <div class="featured-product__grid" {{ block.shopify_attributes }}>
            {%- assign product = block.settings.product -%}
            {%- if product != blank -%}
              <div class="product-card">
                <a href="{{ product.url }}" class="product-card__link">
                  <div class="product-card__image">
                    {%- if product.featured_image != blank -%}
                      {{ product.featured_image | image_url: width: 400 | image_tag }}
                    {%- else -%}
                      <div class="product-card__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
                    {%- endif -%}
                  </div>
                  <div class="product-card__info">
                    <h3 class="product-card__title">{{ product.title }}</h3>
                    <p class="product-card__price">{{ product.price | money }}</p>
                  </div>
                </a>
                <a href="{{ product.url }}" class="btn btn--primary product-card__button">
                  {{ block.settings.button_text }}
                </a>
              </div>
            {%- else -%}
              <div class="product-card">
                <div class="product-card__image product-card__placeholder-image">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
                <div class="product-card__info">
                  <h3 class="product-card__title">Trousse Pompon Rouge</h3>
                  <p class="product-card__price">€89,00</p>
                </div>
                <a href="#" class="btn btn--primary product-card__button">
                  {{ block.settings.button_text }}
                </a>
              </div>
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
  .featured-product {
    padding: 5rem 0;
  }

  .featured-product__container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  .featured-product__title {
    font-family: var(--font-primary--family);
    font-size: 2rem;
    color: var(--color-navy);
    text-align: center;
    margin: 0;
  }

  .featured-product__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    width: 100%;
    max-width: 600px;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-background);
    border-radius: 4px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(15, 45, 61, 0.1);
  }

  .product-card__link {
    text-decoration: none;
    color: inherit;
  }

  .product-card__image {
    aspect-ratio: 1;
    overflow: hidden;
    background-color: var(--color-sand);
  }

  .product-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-card__placeholder-image {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .product-card__placeholder-image svg {
    width: 100%;
    max-width: 200px;
    height: auto;
    opacity: 0.3;
  }

  .product-card__info {
    padding: 1.5rem;
    text-align: center;
  }

  .product-card__title {
    font-family: var(--font-primary--family);
    font-size: 1rem;
    color: var(--color-navy);
    margin: 0 0 0.5rem;
    letter-spacing: 0.05em;
  }

  .product-card__price {
    font-family: var(--font-secondary--family);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-red);
    margin: 0;
  }

  .product-card__button {
    margin: 0 1.5rem 1.5rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Produit en vedette",
  "class": "section-featured-product",
  "blocks": [
    {
      "type": "heading",
      "name": "Titre",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Notre Produit Phare"
        }
      ]
    },
    {
      "type": "product",
      "name": "Produit",
      "limit": 1,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produit"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Texte du bouton",
          "default": "Voir le produit"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Produit en vedette",
      "blocks": [
        { "type": "heading" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
