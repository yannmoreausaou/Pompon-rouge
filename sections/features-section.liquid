<section class="features">
  <div class="features__container content-wrapper">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          <h2 class="features__title" {{ block.shopify_attributes }}>{{ block.settings.title }}</h2>
        {%- when 'feature' -%}
          <div class="feature" {{ block.shopify_attributes }}>
            <div class="feature__icon">
              {{ block.settings.icon }}
            </div>
            <h3 class="feature__title">{{ block.settings.feature_title }}</h3>
            <p class="feature__text">{{ block.settings.feature_text }}</p>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
  .features {
    padding: 5rem 0;
    background-color: var(--color-background);
  }

  .features__container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }

  .features__title {
    font-family: var(--font-primary--family);
    font-size: 2rem;
    color: var(--color-navy);
    text-align: center;
    margin: 0;
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    width: 100%;
  }

  .feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem;
    background-color: var(--color-sand);
    border-radius: 4px;
  }

  .feature__icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-navy);
  }

  .feature__title {
    font-family: var(--font-primary--family);
    font-size: 1rem;
    color: var(--color-navy);
    margin: 0 0 0.75rem;
    letter-spacing: 0.05em;
  }

  .feature__text {
    font-family: var(--font-secondary--family);
    font-size: 0.875rem;
    color: var(--color-foreground);
    margin: 0;
    line-height: 1.6;
  }
{% endstylesheet %}

