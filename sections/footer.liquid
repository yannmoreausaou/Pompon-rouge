<footer class="footer">
  <div class="footer__container">
    <div class="footer__brand">
      <span class="footer__logo">{{ shop.name }}</span>
      <p class="footer__tagline">{{ section.settings.tagline }}</p>
    </div>

    <div class="footer__links">
      <h4 class="footer__links-title">{{ section.settings.menu_title }}</h4>
      {% for link in section.settings.menu.links %}
        <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
      {% endfor %}
    </div>

    <div class="footer__newsletter">
      <h4 class="footer__newsletter-title">{{ section.settings.newsletter_title }}</h4>
      <p class="footer__newsletter-text">{{ section.settings.newsletter_text }}</p>
      {%- form 'customer', id: 'footer-newsletter' -%}
        <input type="email" name="contact[email]" placeholder="Votre email" required>
        <button type="submit" class="btn btn--primary">{{ section.settings.newsletter_button }}</button>
      {%- endform -%}
    </div>

    <div class="footer__payment">
      {% if section.settings.show_payment_icons %}
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag }}
        {% endfor %}
      {% endif %}
    </div>
  </div>

  <div class="footer__bottom">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Tous droits réservés.</p>
  </div>
</footer>

{% stylesheet %}
  .footer {
    background-color: var(--color-navy);
    color: var(--color-background);
    padding: 4rem 0 2rem;
  }

  .footer__container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 3rem;
  }

  .footer__logo {
    font-family: var(--font-primary);
    font-size: 1.5rem;
    letter-spacing: 0.05em;
  }

  .footer__tagline {
    font-family: var(--font-secondary);
    font-size: 0.875rem;
    opacity: 0.8;
    margin-top: 0.5rem;
  }

  .footer__links-title {
    font-family: var(--font-primary);
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .footer__link {
    display: block;
    font-family: var(--font-secondary);
    font-size: 0.875rem;
    color: var(--color-background);
    text-decoration: none;
    opacity: 0.8;
    margin-bottom: 0.5rem;
    transition: opacity 0.2s ease;
  }

  .footer__link:hover {
    opacity: 1;
  }

  .footer__newsletter-title {
    font-family: var(--font-primary);
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .footer__newsletter-text {
    font-family: var(--font-secondary);
    font-size: 0.875rem;
    opacity: 0.8;
    margin-bottom: 1rem;
  }

  .footer__newsletter form {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .footer__newsletter input {
    flex: 1;
    min-width: 180px;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(248, 246, 242, 0.3);
    background: transparent;
    color: var(--color-background);
    font-family: var(--font-secondary);
    font-size: 0.875rem;
  }

  .footer__newsletter input::placeholder {
    color: rgba(248, 246, 242, 0.5);
  }

  .footer__newsletter input:focus {
    outline: none;
    border-color: var(--color-background);
  }

  .footer__payment {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .footer__payment svg {
    height: 1.5rem;
    opacity: 0.8;
  }

  .footer__bottom {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 2rem var(--page-margin) 0;
    margin-top: 3rem;
    border-top: 1px solid rgba(248, 246, 242, 0.2);
  }

  .footer__bottom p {
    font-family: var(--font-secondary);
    font-size: 0.75rem;
    opacity: 0.6;
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "Slogan",
      "default": "L'art de la mer, redéfini."
    },
    {
      "type": "text",
      "id": "menu_title",
      "label": "Titre Menu",
      "default": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Titre Newsletter",
      "default": "Newsletter"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Texte Newsletter",
      "default": "Recevez nos actualités et offres exclusives."
    },
    {
      "type": "text",
      "id": "newsletter_button",
      "label": "Texte bouton",
      "default": "S'inscrire"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
