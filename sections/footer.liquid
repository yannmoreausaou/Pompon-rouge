<footer class="footer">
  <div class="footer__container">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'logo' -%}
          <div class="footer__brand" {{ block.shopify_attributes }}>
            <span class="footer__logo">{{ shop.name }}</span>
            <p class="footer__tagline">{{ block.settings.tagline }}</p>
          </div>
        {%- when 'links' -%}
          <div class="footer__links" {{ block.shopify_attributes }}>
            <h4 class="footer__links-title">{{ block.settings.title }}</h4>
            {%- for link in block.settings.menu.links -%}
              <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
            {%- endfor -%}
          </div>
        {%- when 'newsletter' -%}
          <div class="footer__newsletter" {{ block.shopify_attributes }}>
            <h4 class="footer__newsletter-title">{{ block.settings.title }}</h4>
            <p class="footer__newsletter-text">{{ block.settings.text }}</p>
            {%- form 'customer', id: 'footer-newsletter' -%}
              <input type="email" name="contact[email]" placeholder="Votre email" required>
              <button type="submit" class="btn btn--primary">{{ block.settings.button_text }}</button>
            {%- endform -%}
          </div>
        {%- when 'payment' -%}
          <div class="footer__payment" {{ block.shopify_attributes }}>
            {%- if block.settings.show_payment_icons -%}
              {%- for type in shop.enabled_payment_types -%}
                {{ type | payment_type_svg_tag }}
              {%- endfor -%}
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}

    <div class="footer__bottom">
      <p class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Tous droits réservés.</p>
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    background-color: var(--color-navy);
    color: var(--color-background);
    padding: 4rem 0 2rem;
  }

  .footer__container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
    display: grid;
    gap: 3rem;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__logo {
    font-family: var(--font-primary--family);
    font-weight: var(--font-primary--weight);
    font-size: 1.5rem;
    letter-spacing: 0.05em;
  }

  .footer__tagline {
    font-family: var(--font-secondary--family);
    font-size: 0.875rem;
    opacity: 0.8;
    margin: 0;
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer__links-title {
    font-family: var(--font-primary--family);
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }

  .footer__link {
    font-family: var(--font-secondary--family);
    font-size: 0.875rem;
    color: var(--color-background);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .footer__link:hover {
    opacity: 1;
  }

  .footer__newsletter {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__newsletter-title {
    font-family: var(--font-primary--family);
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }

  .footer__newsletter-text {
    font-family: var(--font-secondary--family);
    font-size: 0.875rem;
    opacity: 0.8;
    margin: 0;
  }

  .footer__newsletter form {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .footer__newsletter input {
    flex: 1;
    min-width: 200px;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(248, 246, 242, 0.3);
    background: transparent;
    color: var(--color-background);
    font-family: var(--font-secondary--family);
    font-size: 0.875rem;
  }

  .footer__newsletter input::placeholder {
    color: rgba(248, 246, 242, 0.5);
  }

  .footer__newsletter input:focus {
    outline: none;
    border-color: var(--color-background);
  }

  .footer__payment {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .footer__payment svg {
    height: 1.5rem;
    opacity: 0.8;
  }

  .footer__bottom {
    border-top: 1px solid rgba(248, 246, 242, 0.2);
    padding-top: 2rem;
    margin-top: 2rem;
  }

  .footer__copyright {
    font-family: var(--font-secondary--family);
    font-size: 0.75rem;
    opacity: 0.6;
    margin: 0;
    text-align: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    font-family: var(--font-secondary--family);
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
    border: none;
  }

  .btn--primary {
    background-color: var(--color-red);
    color: white;
  }

  .btn--primary:hover {
    background-color: #a31f1f;
  }

  .btn--secondary {
    background-color: transparent;
    color: var(--color-navy);
    border: 2px solid var(--color-navy);
  }

  .btn--secondary:hover {
    background-color: var(--color-navy);
    color: var(--color-background);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "class": "section-footer",
  "blocks": [
    {
      "type": "logo",
      "name": "Marque",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "tagline",
          "label": "Slogan",
          "default": "L'art de la mer, redéfini."
        }
      ]
    },
    {
      "type": "links",
      "name": "Liens",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Navigation"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Newsletter"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texte",
          "default": "Recevez nos actualités et offres exclusives."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Texte du bouton",
          "default": "S'inscrire"
        }
      ]
    },
    {
      "type": "payment",
      "name": "Paiement",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_payment_icons",
          "label": "Afficher les icônes de paiement",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "logo" },
        { "type": "links" },
        { "type": "newsletter" },
        { "type": "payment" }
      ]
    }
  ]
}
{% endschema %}
