<section class="hero full-width">
  <div class="hero__content">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'heading' -%}
          <h1 class="hero__title" {{ block.shopify_attributes }}>{{ block.settings.title }}</h1>
        {%- when 'subheading' -%}
          <p class="hero__subtitle" {{ block.shopify_attributes }}>{{ block.settings.subtitle }}</p>
        {%- when 'button' -%}
          <a href="{{ block.settings.button_link }}" class="btn btn--primary hero__button" {{ block.shopify_attributes }}>
            {{ block.settings.button_text }}
          </a>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
  .hero {
    background-color: var(--color-sand);
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem var(--page-margin);
  }

  .hero__content {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero__title {
    font-family: var(--font-primary--family);
    font-size: 3.5rem;
    font-weight: 400;
    color: var(--color-navy);
    letter-spacing: 0.1em;
    margin: 0;
  }

  .hero__subtitle {
    font-family: var(--font-secondary--family);
    font-size: 1.25rem;
    color: var(--color-foreground);
    margin: 0;
    max-width: 600px;
  }

  .hero__button {
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 50vh;
    }

    .hero__title {
      font-size: 2.5rem;
    }

    .hero__subtitle {
      font-size: 1rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "class": "section-hero",
  "blocks": [
    {
      "type": "heading",
      "name": "Titre",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Pompon Rouge"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Sous-titre",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Sous-titre",
          "default": "L'élégance maritime, redéfinie."
        }
      ]
    },
    {
      "type": "button",
      "name": "Bouton",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "label": "Texte du bouton",
          "default": "Découvrir"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Lien du bouton"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "heading" },
        { "type": "subheading" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
