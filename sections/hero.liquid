<section class="hero">
  <div class="hero__container">
    <h1 class="hero__title">{{ section.settings.title }}</h1>
    <p class="hero__subtitle">{{ section.settings.subtitle }}</p>
    <a href="{{ section.settings.button_link }}" class="btn btn--primary">{{ section.settings.button_text }}</a>
  </div>
</section>

{% stylesheet %}
  .hero {
    background-color: var(--color-sand);
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem var(--page-margin);
  }

  .hero__container {
    max-width: 800px;
  }

  .hero__title {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .hero__subtitle {
    font-family: var(--font-secondary);
    font-size: 1.25rem;
    color: var(--color-foreground);
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titre",
      "default": "Pompon Rouge"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "L'élégance maritime, redéfinie."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texte du bouton",
      "default": "Découvrir"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du bouton"
    }
  ]
}
{% endschema %}
