{% style %}
  :root {
    /* Brand Colors */
    --color-navy: #0F2D3D;
    --color-red: #C62828;
    --color-background: #F8F6F2;
    --color-sand: #E8DDC8;
    --color-foreground: #5B6770;

    /* Typography */
    --font-primary: 'Cinzel', serif;
    --font-secondary: 'Montserrat', sans-serif;

    /* Layout */
    --page-width: 90rem;
    --page-margin: 20px;
  }
{% endstyle %}
